{
  "name": "@taskforge/cli",
  "version": "0.5.0",
  "description": "CLI client for the Taskforge API",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "task": "bin/task",
    "task-add": "bin/task-add",
    "task-list": "bin/task-list",
    "task-query": "bin/task-list",
    "task-work-on": "bin/task-work-on",
    "task-next": "bin/task-next",
    "task-todo": "bin/task-todo",
    "task-complete": "bin/task-complete",
    "task-register": "bin/task-register",
    "task-login": "bin/task-login",
    "task-defer": "bin/task-defer"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run clean && npm run build",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run lint",
    "fmt": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "npm run build && TASKFORGE_TOKEN='' TASKFORGE_HOST=http://127.0.0.1:8000/api jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taskforge/cli.git"
  },
  "keywords": [
    "cli",
    "task",
    "task-management",
    "productivity"
  ],
  "author": "Mathew Robinson",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/taskforge/cli/issues"
  },
  "homepage": "https://github.com/taskforge/cli#readme",
  "devDependencies": {
    "@types/commander": "^2.12.2",
    "@types/jest": "^26.0.7",
    "@types/node": "^14.0.26",
    "@types/prompts": "^2.0.8",
    "@types/table": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^3.7.0",
    "@typescript-eslint/parser": "^3.7.0",
    "eslint": "^7.5.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-jest": "^23.17.1",
    "eslint-plugin-prettier": "^3.1.4",
    "jest": "^26.1.0",
    "prettier": "^2.0.5",
    "ts-jest": "^26.1.3",
    "ts-node": "^8.10.2",
    "typescript": "^3.9.7"
  },
  "dependencies": {
    "@taskforge/sdk": "^0.2.7",
    "commander": "^5.1.0",
    "kleur": "^4.0.2",
    "ora": "^4.0.5",
    "prompts": "^2.3.2",
    "table": "^5.4.6"
  }
}
