{
    "name": "@taskforge/cli",
    "version": "0.8.0",
    "description": "CLI client for the Taskforge API",
    "main": "dist/index.js",
    "files": [
        "dist"
    ],
    "bin": {
        "task": "bin/task"
    },
    "scripts": {
        "build": "tsc",
        "prepare": "npm run clean && npm run build",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run lint",
        "fmt": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
        "test": "npm run build && TASKFORGE_TOKEN='' jest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/taskforge/cli.git"
    },
    "keywords": [
        "cli",
        "task",
        "task-management",
        "productivity"
    ],
    "author": "Mathew Robinson",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/taskforge/cli/issues"
    },
    "homepage": "https://github.com/taskforge/cli#readme",
    "devDependencies": {
        "@types/commander": "^2.12.2",
        "@types/jest": "^26.0.20",
        "@types/node": "^14.14.22",
        "@types/node-fetch": "^2.5.8",
        "@types/prompts": "^2.0.9",
        "@types/table": "^5.0.0",
        "@typescript-eslint/eslint-plugin": "^3.10.1",
        "@typescript-eslint/parser": "^3.10.1",
        "eslint": "^7.18.0",
        "eslint-config-prettier": "^6.15.0",
        "eslint-plugin-jest": "^23.20.0",
        "eslint-plugin-prettier": "^3.3.1",
        "jest": "^26.6.3",
        "prettier": "^2.2.1",
        "ts-jest": "^26.5.0",
        "ts-node": "^8.10.2",
        "typescript": "^3.9.7"
    },
    "dependencies": {
        "commander": "^5.1.0",
        "kleur": "^4.1.4",
        "node-fetch": "^2.6.1",
        "ora": "^4.1.1",
        "prompts": "^2.4.0",
        "table": "^5.4.6",
        "yaml": "^1.10.0"
    }
}